# Copy this file to `.env` in the repo root and fill in real values.
# `.env` is gitignored and listed in `.cursorignore` — do not paste keys into Cursor chat.
#
# Default batch path: native Together serverless (see simulation/llm_client.py)
TOGETHER_API_KEY=
